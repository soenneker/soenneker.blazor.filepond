@page "/second"
@using Soenneker.Blazor.FilePond
@using Soenneker.Blazor.FilePond.Dtos
@using Microsoft.Extensions.Logging
@using System.IO
@using Soenneker.Extensions.String
@using Soenneker.Utils.Random
@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <DemoPanel Title="Upload" Description="FilePond surface without extra chrome.">
        <FilePond @ref="FilePond" OnInit="OnInit" OnAddFile="OnAddFile" OnInitFile="OnInitFile" OnBeforeAddFile="OnBeforeAddFile">
        </FilePond>
    </DemoPanel>

    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <DemoPanel Title="File Operations" Description="Add files through different entry points.">
            <DemoButtonRow>
                <Button OnClick="AddFile">Add File</Button>
                <Button OnClick="AddFileSilently">Add File Silently</Button>
                <Button OnClick="AddFileFromStream" Variant="ButtonVariant.Secondary">Add From Stream</Button>
                <Button OnClick="AddLimboFile" Variant="ButtonVariant.Outline">Add Limbo File</Button>
                <Button OnClick="AddFiles" Variant="ButtonVariant.Secondary">Add Multiple Files</Button>
            </DemoButtonRow>
        </DemoPanel>

        <DemoPanel Title="File Management" Description="Browse, inspect, and remove files.">
            <DemoButtonRow>
                <Button OnClick="Browse" Variant="ButtonVariant.Secondary">Browse Files</Button>
                <Button OnClick="GetFile" Variant="ButtonVariant.Outline">Get File</Button>
                <Button OnClick="GetFiles" Variant="ButtonVariant.Outline">Get All Files</Button>
                <Button OnClick="RemoveFile" Variant="ButtonVariant.Destructive">Remove File</Button>
                <Button OnClick="RemoveFiles" Variant="ButtonVariant.Destructive">Remove All Files</Button>
            </DemoButtonRow>
        </DemoPanel>

        <DemoPanel Title="Advanced Features" Description="Stream access and component lifecycle calls.">
            <DemoButtonRow>
                <Button OnClick="GetStreamForFile" Variant="ButtonVariant.Secondary">Get Stream</Button>
                <Button OnClick="Create">Create Component</Button>
                <Button OnClick="Dispose" Variant="ButtonVariant.Destructive">Dispose Component</Button>
            </DemoButtonRow>
        </DemoPanel>

        <DemoPanel Title="Navigation" Description="Move between the focused demo pages.">
            <DemoButtonRow>
                <Button To="/">Back to Main Page</Button>
                <Button To="/validation-demo" Variant="ButtonVariant.Outline">Validation Demo</Button>
            </DemoButtonRow>
        </DemoPanel>
    </Grid>
</Div>

@code{
    private FilePond? FilePond { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
    }

    private void OnInit()
    {
        Logger.LogInformation("OnInit fired");
    }

    private async Task Create()
    {
        await FilePond!.Create();
    }

    private async Task AddFile()
    {
        await FilePond!.AddFile(GetRandomImageUri());
    }

    private async Task AddFileSilently()
    {
        await FilePond!.AddFile(GetRandomImageUri(), true);
    }

    private static string GetRandomImageUri()
    {
        int fileHeight = RandomUtil.Next(200, 500);
        int fileWidth = RandomUtil.Next(200, 500);

        return $"https://picsum.photos/{fileHeight}/{fileWidth}";
    }

    private async Task AddFileFromStream()
    {
        const string test = "Hello world";
        var stream = test.ToMemoryStream();
        await FilePond!.AddFile(stream);
        await stream.DisposeAsync();
    }

    private async Task AddLimboFile()
    {
        await FilePond!.AddLimboFile("test-limbo-file.txt");
    }

    private async Task AddFiles()
    {
        await FilePond!.AddFiles([
            GetRandomImageUri(),
            GetRandomImageUri()
        ]);
    }

    private async Task GetFile()
    {
        FilePondFileItem? result = await FilePond!.GetFile();
    }

    private async Task Browse()
    {
        await FilePond!.Browse();
    }

    private async Task GetStreamForFile()
    {
        Stream? stream = await FilePond!.GetStreamForFile();
        await stream!.DisposeAsync();
    }

    private async Task GetFiles()
    {
        List<FilePondFileItem>? result = await FilePond!.GetFiles();
    }

    private async Task RemoveFile()
    {
        await FilePond!.RemoveFile();
    }

    private async Task RemoveFiles()
    {
        await FilePond!.RemoveFiles();
    }

    private async Task Dispose()
    {
        await FilePond!.Destroy();
    }

    private void OnAddFile((FilePondError? error, FilePondFileItem fileItem) obj)
    {
        Logger.LogInformation("OnAddFile fired: Filename: {fileName}", obj.fileItem.Filename);
    }

    private void OnInitFile(FilePondFileItem file)
    {
        Logger.LogInformation("OnInitFile fired: Filename: {fileName}", file.Filename);
    }

    private ValueTask<bool> OnBeforeAddFile(FilePondFileItem file)
    {
        Logger.LogInformation("OnBeforeAddFile fired: Filename: {fileName}", file.Filename);

        return ValueTask.FromResult(true);
    }

    private ValueTask<string> OnFileRename(FilePondFileRenameInfo file)
    {
        Logger.LogInformation("OnFileRename fired: Filename: {fileName}", file.Name);

        return ValueTask.FromResult("test");
    }
}
